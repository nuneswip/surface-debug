{
    "name": "@nuneswip/inkfish",
    "version": "1.1.3",
    "description": "A simple and powerful logger for your project.",
    "keywords": [
        "inkfish",
        "logger",
        "cli",
        "terminal",
        "console",
        "pretty",
        "spinner",
        "progress",
        "group",
        "box",
        "json",
        "debug",
        "devtools",
        "nodejs"
    ],
    "author": "nuneswip",
    "license": "MIT",
    "homepage": "https://surfacedocs.onrender.com/debug/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nuneswip/surface-debug.git"
    },
    "bugs": {
        "url": "https://github.com/nuneswip/surface-debug/issues"
    },
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "default": "./dist/index.mjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "npx unbuild",
        "test": "npm run build && node test-project/build.js",
        "release": "npm run build && npm publish",
        "fix": "npm version patch && npm run release",
        "feat": "npm version minor && npm run release",
        "major": "npm version major && npm run release"
    },
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "chalk": "^5.4.1",
        "color-name": "^2.1.0",
        "jiti": "^2.6.1"
    },
    "devDependencies": {
        "unbuild": "^3.6.1"
    }
}
